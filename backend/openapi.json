{"openapi": "3.1.0", "info": {"title": "Tech Nest Intelligence Engine", "description": "The Decision Intelligence backend powering Tech Nest.", "version": "2.0.0"}, "paths": {"/api/v1/devices": {"get": {"tags": ["Device Database"], "summary": "List Devices", "description": "List devices from the database.\nUsed by the frontend to display trending devices and browsing lists.", "operationId": "list_devices_api_v1_devices_get", "parameters": [{"name": "category", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Category"}}, {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 100, "minimum": 1, "default": 20, "title": "Limit"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Device"}, "title": "Response List Devices Api V1 Devices Get"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/devices/{device_id}": {"get": {"tags": ["Device Database"], "summary": "Get Device", "description": "Get a single device by its ID.", "operationId": "get_device_api_v1_devices__device_id__get", "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Device"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/devices/{device_id}/decision": {"get": {"tags": ["Device Database"], "summary": "Get Device Decision", "description": "Get the decision intelligence score for a device.\nUsed by TrendingDevices and other UI components to show the Tech Nest Score.", "operationId": "get_device_decision_api_v1_devices__device_id__decision_get", "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"type": "object", "title": "Response Get Device Decision Api V1 Devices  Device Id  Decision Get"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/intelligence/context": {"post": {"tags": ["Intelligence"], "summary": "Update Intelligence Context", "description": "Receives session signals (searches, views, constraints) and updates \nthe Zero-Party Behavioral Layer.\nReturns the current vectorized User Decision State.", "operationId": "update_intelligence_context_api_v1_intelligence_context_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserSignalPayload"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IntelligenceContext"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/intelligence/admin/metrics": {"get": {"tags": ["Intelligence"], "summary": "Get Intelligence Metrics", "description": "Protected Admin Endpoint.\nOnly users with 'admin' or 'super_admin' roles can access this.\nReturns global system intelligence metrics.", "operationId": "get_intelligence_metrics_api_v1_intelligence_admin_metrics_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"type": "object", "title": "Response Get Intelligence Metrics Api V1 Intelligence Admin Metrics Get"}}}}}, "security": [{"HTTPBearer": []}]}}, "/api/v1/intelligence/generate/{device_id}": {"post": {"tags": ["Intelligence Pipeline"], "summary": "Trigger Intelligence Generation", "description": "Triggers intelligence pipeline for a device.\nReturns immediately \u2014 pipeline runs in background.\n\nCalled automatically by publishDeviceAction on the frontend.\nCan also be called manually from the Admin Engine page.", "operationId": "trigger_intelligence_generation_api_v1_intelligence_generate__device_id__post", "security": [{"HTTPBearer": []}], "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GenerateResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/intelligence/regenerate/{device_id}": {"post": {"tags": ["Intelligence Pipeline"], "summary": "Force Regenerate Intelligence", "description": "Force re-runs all intelligence steps, including AI insight regeneration.\nUse when: specs have changed, scoring weights updated, or insights quality improved.", "operationId": "force_regenerate_intelligence_api_v1_intelligence_regenerate__device_id__post", "security": [{"HTTPBearer": []}], "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GenerateResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/intelligence/status/{device_id}": {"get": {"tags": ["Intelligence Pipeline"], "summary": "Get Intelligence Status", "description": "Returns full intelligence status for a device.\nIncludes scores, insight availability, and competitor count.\nPublic endpoint \u2014 no auth required (data is already public).", "operationId": "get_intelligence_status_api_v1_intelligence_status__device_id__get", "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IntelligenceStatusResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/intelligence/bulk-generate": {"post": {"tags": ["Intelligence Pipeline"], "summary": "Bulk Trigger Intelligence", "description": "Bulk-trigger intelligence for multiple devices.\nUseful for bootstrapping the system with existing published devices.\nMax 100 devices per request to avoid overloading the worker pool.", "operationId": "bulk_trigger_intelligence_api_v1_intelligence_bulk_generate_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkGenerateRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkGenerateResponse"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}, "security": [{"HTTPBearer": []}]}}, "/api/v1/decision/orchestrate": {"post": {"tags": ["Decision Engine"], "summary": "Generate Decision", "description": "The Intelligence Heavy Lifter.\n\n1. Fetches network enrichment for all candidate devices (non-blocking: read from\n   device_network_stats \u2014 already aggregated, sub-millisecond query).\n2. Adjust confidence_score based on network_multiplier signal:\n     - multiplier > 1.2 \u2192 strong behavioral confirmation \u2192 confidence +0.05\n     - multiplier < 0.8 \u2192 behavioral concern    \u2192 confidence -0.07\n3. Run deterministic spec-based scoring for BUY/WAIT/SKIP verdict.\n4. Log start_decision events for all considered devices (background).\n5. Log decision memory for the top-verdict device (background).", "operationId": "generate_decision_api_v1_decision_orchestrate_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"items": {"$ref": "#/components/schemas/DeviceVerdict"}, "type": "array", "title": "Response Generate Decision Api V1 Decision Orchestrate Post"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/knowledge-graph/adjacencies/{device_id}": {"get": {"tags": ["Knowledge Graph"], "summary": "Get Device Knowledge Graph", "description": "Returns highly correlated alternatives and upgrade lineages using pgvector cosine distance.", "operationId": "get_device_knowledge_graph_api_v1_knowledge_graph_adjacencies__device_id__get", "parameters": [{"name": "device_id", "in": "path", "required": true, "schema": {"type": "string", "title": "Device Id"}}, {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "default": 4, "title": "Limit"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/market-signals/ingest": {"put": {"tags": ["Market Signals"], "summary": "Ingest Market Signal", "description": "Fire-and-forget behavioral logging endpoint for continuous learning.", "operationId": "ingest_market_signal_api_v1_market_signals_ingest_put", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/SignalIngestion"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/advisor/feed": {"get": {"tags": ["Personal Advisor"], "summary": "Get Advisor Feed", "description": "Retrieve the sorted, pre-computed Advisor Feed.\nThis feed represents proactive insights (Upgrades, Prices, Recommendations).", "operationId": "get_advisor_feed_api_v1_advisor_feed_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdvisorFeedResponse"}}}}}}}, "/api/v1/advisor/refresh": {"post": {"tags": ["Personal Advisor"], "summary": "Manual Trigger Advisor", "description": "Manually kick off the background re-computation of preference weights,\nupgrade predictions, and event feed generation.", "operationId": "manual_trigger_advisor_api_v1_advisor_refresh_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/ForceRefreshRequest"}}}, "required": true}, "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/network/event": {"post": {"tags": ["Intelligence Network"], "summary": "Record Interaction Event", "description": "Fire-and-forget event ingestion from any client (Next.js, mobile).\nReturns 202 immediately \u2014 the actual DB write happens in background.\nThis design keeps frontend interactions sub-5ms from the API's perspective.", "operationId": "record_interaction_event_api_v1_network_event_post", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/InteractionEventRequest"}}}, "required": true}, "respo