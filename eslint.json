onGateway() {\r\n  const commonComparisons = [\r\n    { name: \"Samsung Galaxy S24 Ultra\", label: \"Flagship Android Rival\" },\r\n    { name: \"iPhone 15 Pro\", label: \"Previous Generation\" },\r\n    { name: \"Google Pixel 9 Pro\", label: \"Top Camera Alternative\" },\r\n    { name: \"iPhone 16 Pro Max\", label: \"Bigger Battery Variant\" },\r\n  ];\r\n\r\n  return (\r\n    <section className=\"w-full max-w-5xl mx-auto px-6 py-16 border-t bg-background\">\r\n      <div className=\"flex flex-col mb-10\">\r\n        <h2 className=\"text-2xl font-semibold tracking-tight text-foreground\">\r\n          Comparison Gateway\r\n        </h2>\r\n        <p className=\"text-muted-foreground text-[15px] mt-2\">\r\n          Don't guess. See exact side-by-side differences.\r\n        </p>\r\n      </div>\r\n\r\n      <div className=\"grid md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n        {commonComparisons.map((comp, idx) => (\r\n          <button \r\n            key={idx}\r\n            className=\"flex flex-col p-6 rounded-3xl bg-surface border border-border-subtle hover:border-text-primary/20 hover:bg-surface-elevated hover:shadow-premium-md group transition-all duration-300 ease-calm text-left relative overflow-hidden\"\r\n          >\r\n            <div className=\"w-10 h-10 rounded-xl bg-bg-primary border border-border-subtle flex items-center justify-center mb-6 transition-colors\">\r\n               <ArrowRightLeft className=\"w-4 h-4 text-text-secondary/60\" />\r\n            </div>\r\n            \r\n            <span className=\"text-text-secondary text-xs font-semibold uppercase tracking-wider mb-2 line-clamp-1\">\r\n              vs {comp.label}\r\n            </span>\r\n            <span className=\"text-text-primary font-medium text-lg leading-tight line-clamp-2\">\r\n              {comp.name}\r\n            </span>\r\n          </button>\r\n        ))}\r\n      </div>\r\n      \r\n      <div className=\"mt-8\">\r\n        <button className=\"flex items-center gap-2 text-[15px] font-medium text-text-secondary hover:text-text-primary transition-colors mx-auto underline decoration-text-primary/20 hover:decoration-text-primary/40 underline-offset-4\">\r\n          Compare with any custom device\r\n        </button>\r\n      </div>\r\n    </section>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\DecisionSummary.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'device' is defined but never used.","line":3,"column":43,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":49}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { CheckCircle2, XCircle, ChevronRight, Activity } from \"lucide-react\";\r\n\r\nexport default function DecisionSummary({ device, decision }: { device?: any, decision?: any }) {\r\n  const bestFor = decision?.best_for || [\"Day-to-day Usability\", \"General Purpose\"];\r\n  const notIdealFor = decision?.not_ideal_for || [\"None specifically\"];\r\n  \r\n  // Safe default for SSR if decision is missing or loading\r\n  const pillars = decision?.pillars || {};\r\n  const pillarKeys = Object.keys(pillars);\r\n\r\n  return (\r\n    <section className=\"w-full max-w-5xl mx-auto px-6 py-16 border-t bg-background\">\r\n      <div className=\"flex flex-col mb-12\">\r\n        <h2 className=\"text-3xl font-medium tracking-tight text-text-primary\">\r\n          Decision Matrix\r\n        </h2>\r\n        <p className=\"text-text-secondary text-sm font-medium mt-2 flex items-center gap-2\">\r\n          <Activity className=\"w-4 h-4 text-text-primary/40\" />\r\n          Powered by Tech Nest Intelligence Engine\r\n        </p>\r\n      </div>\r\n\r\n      <div className=\"grid md:grid-cols-2 gap-8 mb-12\">\r\n        {/* Best For */}\r\n        <div className=\"flex flex-col p-8 rounded-3xl bg-surface border border-border-subtle shadow-[0_0_30px_rgba(0,0,0,0.02)]\">\r\n          <div className=\"flex items-center gap-3 mb-6\">\r\n            <CheckCircle2 className=\"w-5 h-5 text-text-primary/40\" />\r\n            <h3 className=\"text-xs font-semibold uppercase tracking-widest text-text-secondary\">\r\n              Best For\r\n            </h3>\r\n          </div>\r\n          <ul className=\"flex flex-col gap-4\">\r\n            {bestFor.map((item: string, i: number) => (\r\n              <li key={i} className=\"flex items-start gap-3 text-text-secondary leading-relaxed\">\r\n                <ChevronRight className=\"w-4 h-4 text-text-primary/40 shrink-0 mt-1\" />\r\n                <span className=\"text-text-primary font-medium text-15px\">{item}</span>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </div>\r\n\r\n        {/* Not Ideal For */}\r\n        <div className=\"flex flex-col p-8 rounded-3xl bg-surface border border-border-subtle shadow-[0_0_30px_rgba(0,0,0,0.02)] relative overflow-hidden\">\r\n          <div className=\"absolute top-0 left-0 w-1 h-full bg-destructive/20\" />\r\n          <div className=\"flex items-center gap-3 mb-6\">\r\n            <XCircle className=\"w-5 h-5 text-destructive/60\" />\r\n            <h3 className=\"text-xs font-semibold uppercase tracking-widest text-text-secondary\">\r\n              Not Ideal For\r\n            </h3>\r\n          </div>\r\n          <ul className=\"flex flex-col gap-4\">\r\n            {notIdealFor.map((item: string, i: number) => (\r\n              <li key={i} className=\"flex items-start gap-3 text-text-secondary leading-relaxed\">\r\n                <ChevronRight className=\"w-4 h-4 text-destructive/40 shrink-0 mt-1\" />\r\n                <span className=\"text-text-primary font-medium text-15px\">{item}</span>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </div>\r\n      </div>\r\n\r\n      {/* The 6 Pillars Breakdown */}\r\n      {pillarKeys.length > 0 && (\r\n        <div className=\"flex flex-col p-8 md:p-12 rounded-3xl bg-surface border border-border-subtle shadow-[0_0_30px_rgba(0,0,0,0.02)]\">\r\n          <h3 className=\"text-xl font-semibold tracking-tight text-text-primary mb-8\">Algorithm Breakdown</h3>\r\n          <div className=\"grid md:grid-cols-2 gap-x-12 gap-y-8\">\r\n            {pillarKeys.map((key) => {\r\n              const pillar = pillars[key];\r\n              const percentage = Math.round((pillar.score / 10) * 100);\r\n              \r\n              // Dynamic color based on score health, muted slightly for calm aesthetic\r\n              let colorLine = \"bg-text-primary\";\r\n              if (pillar.score < 6) colorLine = \"bg-destructive/80\";\r\n              else if (pillar.score < 8) colorLine = \"bg-amber-500/80\";\r\n              else if (pillar.score >= 9) colorLine = \"bg-text-primary\";\r\n\r\n              return (\r\n                <div key={key} className=\"flex flex-col gap-2\">\r\n                  <div className=\"flex justify-between items-end\">\r\n                    <span className=\"text-sm font-semibold capitalize text-text-primary\">\r\n                      {key.replace(\"_\", \" \")}\r\n                    </span>\r\n                    <span className=\"text-sm font-semibold text-text-primary tabular-nums\">\r\n                      {pillar.score.toFixed(1)} <span className=\"text-text-secondary\">/ 10</span>\r\n                    </span>\r\n                  </div>\r\n                  \r\n                  {/* Progress Bar Container */}\r\n                  <div className=\"h-1.5 w-full bg-text-primary/5 rounded-full overflow-hidden\">\r\n                    <div \r\n                      className={`h-full ${colorLine} rounded-full transition-all duration-1000 ease-out`}\r\n                      style={{ width: `${percentage}%` }}\r\n                    />\r\n                  </div>\r\n                  \r\n                  <p className=\"text-xs text-text-secondary mt-1 font-medium leading-relaxed\">\r\n                    {pillar.explanation}\r\n                  </p>\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </section>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\DeviceHero.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\FinalDecisionCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\FullSpecs.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\KeySpecs.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\RelatedDevices.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\ScoreBreakdown.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Documents\\tech-nest\\src\\components\\device\\SmartSpecs.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-va